model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  password           String
  phone              String?
  address            String?
  city               String?
  avatar             String?
  role               UserRole
  status             UserStatus         @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}